{
  "id": "builtin.generate-audio.qwen3-tts-customvoice",
  "backend": "pytorch",
  "task_type": "text_to_audio",
  "family": "pytorch.qwen_tts_custom_voice",
  "source": {
    "repo_id": "Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice"
  },
  "download_manifest": {
    "include": [],
    "exclude": [],
    "required": [
      "config.json",
      "**/*.json",
      "**/*.safetensors"
    ]
  },
  "load_config": {},
  "prerequisites": {
    "host_binaries": [
      "sox"
    ],
    "install_hint": "Install it on the host with `brew install sox`."
  },
  "defaults": {
    "language": "Auto",
    "speaker": "Vivian",
    "do_sample": true,
    "top_k": 50,
    "top_p": 1.0,
    "temperature": 0.9,
    "repetition_penalty": 1.05,
    "max_new_tokens": 4096,
    "non_streaming_mode": true,
    "seed": 42
  }
}
